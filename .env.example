# Clara AI Automation Pipeline - Environment Variables

# LLM Configuration (Choose one - all have free tiers)
# Option 1: Anthropic Claude (Recommended - free credits on new accounts)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option 2: OpenAI GPT-4 (free trial credits)
OPENAI_API_KEY=your_openai_api_key_here

# Option 3: Local Ollama (completely free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# LLM Provider Selection (anthropic, openai, or ollama)
LLM_PROVIDER=anthropic

# Storage Configuration
# Option 1: Local JSON + Git (default, completely free)
STORAGE_TYPE=local

# Option 2: Supabase (free tier)
# STORAGE_TYPE=supabase
# SUPABASE_URL=your_supabase_project_url
# SUPABASE_KEY=your_supabase_anon_key

# n8n Configuration (for Docker setup)
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_HOST=localhost

# Retell AI Configuration (free account)
RETELL_API_KEY=your_retell_api_key_here
RETELL_AGENT_VOICE=professional-female

# Task Tracker Integration (optional)
# ASANA_ACCESS_TOKEN=your_asana_token_here
# TRELLO_API_KEY=your_trello_key_here
# TRELLO_TOKEN=your_trello_token_here

# Processing Configuration
MAX_RETRIES=3
TIMEOUT_SECONDS=30
LOG_LEVEL=INFO

# Output Configuration
OUTPUT_DIR=./outputs/accounts
LOG_DIR=./logs
